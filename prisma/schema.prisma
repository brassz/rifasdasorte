// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  purchases Purchase[]
  raffles  Raffle[] @relation("RaffleOwner")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Raffle {
  id          String      @id @default(cuid())
  title       String
  description String?
  image       String?
  totalNumbers Int
  pricePerNumber Float
  startDate   DateTime?
  endDate     DateTime?
  status      String      @default("ACTIVE")
  winnerNumber Int?
  winnerId    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  ownerId     String

  owner     User       @relation("RaffleOwner", fields: [ownerId], references: [id])
  numbers   RaffleNumber[]
  purchases Purchase[]
  packages  Package[]
}

model RaffleNumber {
  id        String   @id @default(cuid())
  number    Int
  isSold    Boolean  @default(false)
  raffleId  String
  createdAt DateTime @default(now())

  raffle Raffle @relation(fields: [raffleId], references: [id], onDelete: Cascade)

  @@unique([raffleId, number])
}

model Package {
  id          String  @id @default(cuid())
  name        String
  description String?
  numbers     Int
  price       Float
  discount    Float?  @default(0)
  isActive    Boolean @default(true)
  raffleId    String

  raffle Raffle @relation(fields: [raffleId], references: [id], onDelete: Cascade)
}

model Purchase {
  id        String        @id @default(cuid())
  numbers   String        // JSON array of numbers
  total     Float
  status    String        @default("PENDING")
  paymentId String?
  clientName String?
  clientCpf  String?
  pixCode    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  userId    String
  raffleId  String

  user   User   @relation(fields: [userId], references: [id])
  raffle Raffle @relation(fields: [raffleId], references: [id])

  @@index([userId])
  @@index([raffleId])
}
